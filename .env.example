# ──────────────────────────────────────────────────────
#  AI Trader — Environment Configuration
#  Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────

# ── Zerodha KiteConnect ──────────────────────────────
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
KITE_ACCESS_TOKEN=                    # auto-filled after first login
KITE_REDIRECT_URL=http://localhost:8080

# ── Capital ──────────────────────────────────────────
TRADING_CAPITAL=100000                # paper capital in INR

# ── Ollama AI ────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
AI_MODEL=mistral                       # or: deepseek-r1, llama3, phi3

# ── Logging ──────────────────────────────────────────
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR
